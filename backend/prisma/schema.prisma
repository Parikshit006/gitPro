// ============================================================
// GitPro Prisma Schema
//
// This schema defines the database models for the GitPro
// Engineering Intelligence Platform.
//
// Database: PostgreSQL
// ORM: Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// User Model
//
// Represents a GitPro user authenticated via GitHub OAuth.
// GitHub ID is the external identity key.
// Internal UUID is the primary key used across all GitPro domains.
// ============================================================

model User {
  id          String    @id @default(uuid()) @db.Uuid
  githubId    BigInt    @unique @map("github_id") @db.BigInt
  username    String
  displayName String    @map("display_name")
  avatarUrl   String    @map("avatar_url") @db.Text
  profileUrl  String    @map("profile_url") @db.Text
  email       String?
  isActive    Boolean   @default(true) @map("is_active")
  provider    String    @default("github")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")

  @@index([username])
  @@index([email])
  @@map("users")
}
